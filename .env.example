# Core infrastructure defaults for Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iaverse
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/iaverse
REDIS_URL=redis://redis:6379/0

# Internal service URLs
API_BASE_URL=http://api:8000
FRONTEND_API_UPSTREAM=api:8000

# Runtime options
WORKER_COUNT=4
MODEL_CACHE_DIR=/var/models
MODEL_MAX_CONCURRENCY=4
EXTERNAL_DECISION_RATE=0.10
LOCAL_MODEL_TIMEOUT=20
EXTERNAL_MODEL_TIMEOUT=60
ALLOW_PRIVATE_KEY_FRONTEND=false

# Secrets (replace in real deployments)
WALLET_MASTER_KEY=dev-master-key-change-me
OPERATOR_PASSPHRASE=

# Optional provider integrations
LOCAL_LLM_RATIO=0.9
OLLAMA_HOST=http://localhost:11434
VLLM_ENDPOINT=http://localhost:8000
OPENCLAW_ENDPOINT=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
